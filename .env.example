LOSTFOUND_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/lostfound
LOSTFOUND_DB_ECHO=false
LOSTFOUND_JWT_SECRET_KEY=CHANGE_ME
LOSTFOUND_JWT_ALGORITHM=HS256
LOSTFOUND_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
LOSTFOUND_AUTH_LOGIN_RATE_LIMIT=10
LOSTFOUND_AUTH_LOGIN_RATE_WINDOW_SECONDS=60
LOSTFOUND_AUTH_REGISTER_RATE_LIMIT=5
LOSTFOUND_AUTH_REGISTER_RATE_WINDOW_SECONDS=300
LOSTFOUND_ITEM_WRITE_RATE_LIMIT=20
LOSTFOUND_ITEM_WRITE_RATE_WINDOW_SECONDS=60
LOSTFOUND_CLAIM_SUBMIT_RATE_LIMIT=10
LOSTFOUND_CLAIM_SUBMIT_RATE_WINDOW_SECONDS=300
LOSTFOUND_CLAIM_DECISION_RATE_LIMIT=20
LOSTFOUND_CLAIM_DECISION_RATE_WINDOW_SECONDS=60
LOSTFOUND_AUTO_CREATE_SCHEMA_ON_STARTUP=true
LOSTFOUND_REPAIR_SCHEMA_ON_STARTUP=true
